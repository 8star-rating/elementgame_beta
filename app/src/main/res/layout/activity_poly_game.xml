<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#6C97FA"
    tools:context=".PolyGame">

    <TextView
        android:id="@+id/that_questions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="190dp"
        android:fontFamily="@font/courier_prime"
        android:text="Polyatomic Ion:"
        android:textAlignment="center"
        android:textColor="#1E103B"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/random_ion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/that_questions"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:text="@string/placeholder"
        android:fontFamily="@font/courier_prime"
        android:textAlignment="center"
        android:textColor="#616068"
        android:textSize="85sp"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/input4"
        android:layout_width="250dp"
        android:layout_height="48dp"
        android:layout_centerHorizontal="true"
        android:background="@android:drawable/editbox_background"
        android:hint="@string/type_ion_name"
        android:textColorHint="#626569"
        android:backgroundTint="#F0F0FF"
        android:importantForAutofill="no"
        android:inputType="textCapSentences"
        android:textAlignment="center"
        android:textSize="15sp"
        android:textColor="@color/black"
        android:layout_below="@+id/random_ion"
        android:fontFamily="@font/courier_prime"
        android:layout_marginTop="50dp" />

    <Button
        android:id="@+id/submit4"
        android:layout_width="160dp"
        android:layout_height="50dp"
        android:layout_below="@+id/input4"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:text="@string/submit_game"
        android:textColor="@color/black"
        android:backgroundTint="#F0F0FF"
        />

</RelativeLayout>